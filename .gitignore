.Rproj.user
.Rhistory
.RData
.Ruserdata
/corpus/test/
/corpus/
classification.R
aggregation.R
/utils/strip_epub.R
/private/
/out/*
/.venv/
__pycache__/
/.claude/
/experiments/
/docs/
._*
/tests/

# Training pipeline — lives in its own git repo
training/
/training/*

# Large transformer weights (users fetch from HuggingFace)
/models/trankit_fr_v1/xlm-roberta-base/models--xlm-roberta-base/blobs/
/models/trankit_fr_v1/xlm-roberta-base/models--xlm-roberta-base/snapshots/*/model.safetensors

# Large UDPipe model — hosted as a GitHub release asset, fetched by
# R/artefact_builders/fetch_udpipe_models.R
/models/french_gsd-remix_3.udpipe

# CEFLE — fetched by each user from Lund University; not redistributable (ELRA license)
demo_corpora/cefle_corpus_texts.csv

# Alector derived artefacts — built locally from bundled zip; not redistributable (CC BY-NC-ND)
demo_corpora/alector_corpus.csv
demo_corpora/alector_metadata.csv
demo_corpora/alector/

# Viki-Wiki demo corpus — distributed as demo_corpora/viki_wiki.zip
demo_corpora/viki_wiki/
# Large derived viki-wiki dump — not redistributable, fetched/built locally
demo_corpora/wikiviki_dump_*.tsv

# LexConn — removed from the public repo until its license is clarified with
# the author. The fetcher is kept locally only.
R/artefact_builders/fetch_lexconn.R

# Lexical databases — only Lexique3 (CC license) is redistributable.
# All other built/raw lexical resources (EQOL, FleLex, Manulex, LexConn,
# raw downloads, etc.) are excluded; each user fetches/builds them locally
# via R/artefact_builders/fetch_*.R.
lexical_dbs/*
!lexical_dbs/dt_lexique3.Rds

# Local/downloaded models. Only the small bundled calibration/prototype models
# below are committed; users fetch the remaining model artefacts locally.
models/*
!models/pos_trigram_fr_gsd_alsi.Rds
!models/gam_sent_length_calibration.Rds

# Burstiness norms — prepared internally (building them needs the
# non-distributed wikiviki dump) and shipped pre-built. Only the final
# aggregate .Rds norm tables are tracked; parse caches and the builder
# script stay local. The norms are aggregate per-word statistics derived
# from CC BY-SA Wikipedia/Vikidia text.
/norms/*
!/norms/burstiness_viki.Rds
!/norms/burstiness_wiki.Rds
!/norms/burstiness_wikiviki.Rds
R/artefact_builders/build_wikiviki_norms.R

# Training data and tooling — maintainer-internal, not user-facing.
# /corpora/ holds GSD training splits (rebuildable: fetch_verbpos_conllu.R
# downloads official French-GSD UD r2.16 and applies the ALSI verbpos retag;
# build_pos_ngrams.R fits the POS trigram model that ships pre-built as
# models/pos_trigram_fr_gsd_alsi.Rds).
/corpora/
R/artefact_builders/fetch_verbpos_conllu.R
R/artefact_builders/build_pos_ngrams.R

# Root markdown — only README, FEATURES, LICENSE are distributed.
# Agent/working docs (AGENTS, CLAUDE, DESLOPPIFY_R, etc.) stay local.
/*.md
!/README.md
!/FEATURES.md
!/LICENSE.md

# Stray R/build artifacts
Rplots.pdf
index.html
.DS_Store

